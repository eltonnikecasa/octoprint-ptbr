#, python-format
msgid ""
"Enjoying OctoPrint? Looks like it! <a href=\"%(url)s\" target=\"_blank\" "
"rel=\"noopener noreferrer\">It might be time to give something back "
"then</a> - thank you!"
msgstr ""
"Gostando do OctoPrint? Parece que sim! <a href=\"%(url)s\" target=\"_blank\" "
"rel=\"noopener noreferrer\">Então pode ser hora de retribuir</a> - obrigado!"

#: src/octoprint/plugins/achievements/static/js/achievements.js:307
#, python-format
msgid ""
"Getting value from OctoPrint? <a href=\"%(url)s\" target=\"_blank\" "
"rel=\"noopener noreferrer\">Then please consider supporting its sole "
"maintainer with a donation</a> - thank you!"
msgstr ""
"Obtendo valor do OctoPrint? <a href=\"%(url)s\" target=\"_blank\" "
"rel=\"noopener noreferrer\">Então considere apoiar seu único mantenedor com uma doação</a> - obrigado!"

#: src/octoprint/plugins/achievements/static/js/achievements.js:310
#, python-format
msgid ""
"Has OctoPrint helped you enjoy your printer more? <a href=\"%(url)s\" "
"target=\"_blank\" rel=\"noopener noreferrer\">Then please consider "
"supporting its continued development</a> - thank you!"
msgstr ""
"O OctoPrint ajudou você a aproveitar mais sua impressora? <a "
"href=\"%(url)s\" target=\"_blank\" rel=\"noopener noreferrer\">Então considere "
"apoiar seu desenvolvimento contínuo</a> - obrigado!"

