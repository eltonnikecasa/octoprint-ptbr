msgid "Graph"
msgstr "Gráfico"

#: src/octoprint/templates/dialogs/settings/temperatures.jinja2:4
msgid "Graph cutoff"
msgstr "Corte do gráfico"

#: src/octoprint/templates/dialogs/settings/temperatures.jinja2:10
