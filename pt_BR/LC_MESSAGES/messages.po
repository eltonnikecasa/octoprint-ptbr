#: src/octoprint/access/permissions.py:274
msgid "Admin is allowed to do everything"
msgstr "Administrador tem permissão para fazer tudo"

#: src/octoprint/access/permissions.py:282
msgid ""
"Allows to gather basic status information, e.g. job progress, printer "
"state, temperatures, ... Mandatory for the default UI to work"
msgstr ""
"Permite coletar informações básicas de status, ex. progresso do trabalho, "
"estado da impressora, temperaturas, ... Obrigatório para o funcionamento da interface padrão"

#: src/octoprint/access/permissions.py:293
msgid "Allows to connect to and disconnect from a printer"
msgstr "Permite conectar e desconectar de uma impressora"

#: src/octoprint/access/permissions.py:300
msgid "Allows to watch the webcam stream"
msgstr "Permite assistir ao stream da webcam"

#: src/octoprint/access/permissions.py:307
msgid ""
"Allows to run system commands, e.g. restart OctoPrint, shutdown or reboot"
" the system, and to retrieve system and usage information"
msgstr ""
"Permite executar comandos do sistema, ex. reiniciar o OctoPrint, desligar ou reiniciar"
" o sistema, e recuperar informações do sistema e de uso"

#: src/octoprint/access/permissions.py:317
msgid ""
"Allows to retrieve a list of all uploaded files and folders, "
"including their metadata (e.g. date, file size, analysis results, ...)"
msgstr ""
"Permite recuperar uma lista de todos os arquivos e pastas enviados, "
"incluindo seus metadados (ex. data, tamanho do arquivo, resultados de análise, ...)"

#: src/octoprint/access/permissions.py:326
msgid ""
"Allows users to upload new files, create new folders and copy existing "
"ones. If the File Delete permission is also set, File Upload also allows "
"moving files and folders."
msgstr ""
"Permite que usuários enviem novos arquivos, criem novas pastas e copiem as "
"existentes. Se a permissão de Exclusão de Arquivo também estiver definida, o Envio de Arquivo também permite "
"mover arquivos e pastas."

#: src/octoprint/access/permissions.py:336
msgid ""
"Allows users to download files. The GCODE viewer is affected by this as "
"well."
msgstr ""
"Permite que usuários baixem arquivos. O visualizador GCODE também é afetado por "
"isso."

#: src/octoprint/access/permissions.py:345
msgid ""
"Allows users to delete files and folders. If the File Upload permission "
"is also set, File Delete also allows moving files and folders."
msgstr ""
"Permite que usuários excluam arquivos e pastas. Se a permissão de Envio de Arquivo "
"também estiver definida, a Exclusão de Arquivo também permite mover arquivos e pastas."

#: src/octoprint/access/permissions.py:354
msgid "Allows to select a file for printing"
msgstr "Permite selecionar um arquivo para impressão"

#: src/octoprint/access/permissions.py:361
msgid "Allows to start, pause and cancel a print job"
msgstr "Permite iniciar, pausar e cancelar um trabalho de impressão"

#: src/octoprint/access/permissions.py:368
msgid ""
"Allows access to the GCODE viewer if the \"File Download\" permission is "
"also set."
msgstr ""
"Permite acesso ao visualizador GCODE se a permissão \"Download de Arquivo\" "
"também estiver definida."

#: src/octoprint/access/permissions.py:378
msgid ""
"Allows to watch the terminal tab but not to send commands to the printer "
"from it"
msgstr ""
"Permite visualizar a aba do terminal mas não enviar comandos para a impressora "
"a partir dela"

#: src/octoprint/access/permissions.py:388
msgid ""
"Allows to control of the printer by using the temperature controls, the "
"control tab or sending commands through the terminal."
msgstr ""
"Permite o controle da impressora usando os controles de temperatura, a "
"aba de controle ou enviando comandos através do terminal."

#: src/octoprint/access/permissions.py:398
msgid "Allows to slice files"
msgstr "Permite fatiar arquivos"

#: src/octoprint/access/permissions.py:405
msgid "Allows to list timelapse videos"
msgstr "Permite listar vídeos timelapse"

#: src/octoprint/access/permissions.py:411
msgid "Allows to download timelapse videos"
msgstr "Permite baixar vídeos timelapse"

#: src/octoprint/access/permissions.py:417
msgid "Allows to delete timelapse videos"
msgstr "Permite excluir vídeos timelapse"

#: src/octoprint/access/permissions.py:423
msgid "Allows to list, delete and render unrendered timelapses"
msgstr ""
"Permite listar, excluir e renderizar timelapses não renderizados"

#: src/octoprint/access/permissions.py:429
msgid "Allows to change the timelapse settings."
msgstr "Permite alterar as configurações de timelapse."

#: src/octoprint/access/permissions.py:436
msgid ""
"Allows to read non sensitive settings. Mandatory for the default UI to "
"work."
msgstr ""
"Permite ler configurações não sensíveis. Obrigatório para o funcionamento da interface padrão."

#: src/octoprint/access/permissions.py:445
msgid "Allows to manage settings and also to read sensitive settings"
msgstr "Permite gerenciar configurações e também ler configurações sensíveis"

#: src/octoprint/plugins/achievements/__init__.py:129
msgid "Allows to view the instance achievements & stats."
msgstr "Permite visualizar as conquistas e estatísticas da instância."

#: src/octoprint/plugins/achievements/__init__.py:138
msgid "Allows to reset the instance achievements & stats."
msgstr "Permite redefinir as conquistas e estatísticas da instância."

