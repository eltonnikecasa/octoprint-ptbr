#: src/octoprint/plugins/tracking/templates/tracking_settings.jinja2:14
msgid "Instance ID"
msgstr "ID da Instância"

#: src/octoprint/plugins/errortracking/templates/errortracking_settings.jinja2:35
msgid ""
"\n"
"<p>\n"
"    The Error Tracking plugin is using a Sentry instance kindly provided "
"by\n"
"    <a href=\"https://sentry.io/\" target=\"_blank\" rel=\"noopener "
"noreferrer\">sentry.io</a>. For information on their service\n"
"    please refer to their <a href=\"https://sentry.io/security/\" "
"target=\"_blank\" rel=\"noopener noreferrer\">Security & Compliance "
"documentation</a>\n"
"    and their <a href=\"https://sentry.io/privacy/\" target=\"_blank\" "
"rel=\"noopener noreferrer\">Privacy Policy</a>.\n"
"</p>\n"
msgstr ""
"\n"
"<p>\n"
"    O plugin de Rastreamento de Erros está usando uma instância Sentry gentilmente fornecida por\n"
"    <a href=\"https://sentry.io/\" target=\"_blank\" rel=\"noopener noreferrer\">sentry.io</a>. Para informações sobre o serviço deles,\n"
"    consulte a <a href=\"https://sentry.io/security/\" target=\"_blank\" rel=\"noopener noreferrer\">documentação de Segurança e Conformidade</a>\n"
"    e a <a href=\"https://sentry.io/privacy/\" target=\"_blank\" rel=\"noopener noreferrer\">Política de Privacidade</a>.\n"
"</p>\n"

