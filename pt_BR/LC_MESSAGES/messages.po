#: src/octoprint/server/api/system.py:262
#: src/octoprint/templates/snippets/settings/server/serverCommandSystemShutdown.jinja2:2
msgid "Shutdown system"
msgstr "Desligar sistema"

#: src/octoprint/server/api/system.py:263
msgid ""
"<strong>You are about to shutdown the system.</strong></p><p>This action "
"may disrupt any ongoing print jobs (depending on your printer's "
"controller and general setup that might also apply to prints run directly"
" from your printer's internal storage)."
msgstr ""
"<strong>Você está prestes a desligar o sistema.</strong></p><p>Esta ação "
"pode interromper qualquer trabalho de impressão em andamento (dependendo do controlador da sua impressora e da configuração geral, isso também pode se aplicar a impressões executadas diretamente do armazenamento interno da impressora)."

#: src/octoprint/server/api/system.py:270
msgid "Reboot system"
msgstr "Reiniciar sistema"

#: src/octoprint/server/api/system.py:271
msgid ""
"<strong>You are about to reboot the system.</strong></p><p>This action "
"may disrupt any ongoing print jobs (depending on your printer's "
"controller and general setup that might also apply to prints run directly"
" from your printer's internal storage)."
msgstr ""
"<strong>Você está prestes a reiniciar o sistema.</strong></p><p>Esta ação "
"pode interromper qualquer trabalho de impressão em andamento (dependendo do controlador da sua impressora e da configuração geral, isso também pode se aplicar a impressões executadas diretamente do armazenamento interno da impressora)."

#: src/octoprint/server/api/system.py:278
#: src/octoprint/templates/snippets/settings/server/serverCommandServerRestart.jinja2:2
msgid "Restart OctoPrint"
msgstr "Reiniciar OctoPrint"

#: src/octoprint/server/api/system.py:279
msgid ""
"<strong>You are about to restart the OctoPrint "
"server.</strong></p><p>This action may disrupt any ongoing print jobs "
"(depending on your printer's controller and general setup that might also"
" apply to prints run directly from your printer's internal storage)."
msgstr ""
"<strong>Você está prestes a reiniciar o servidor OctoPrint.</strong></p><p>Esta ação "
"pode interromper qualquer trabalho de impressão em andamento (dependendo do controlador da sua impressora e da configuração geral, isso também pode se aplicar a impressões executadas diretamente do armazenamento interno da impressora)."

#: src/octoprint/server/api/system.py:285
msgid "Restart OctoPrint in safe mode"
msgstr "Reiniciar OctoPrint em modo de segurança"

#: src/octoprint/server/api/system.py:286
msgid ""
"<strong>You are about to restart the OctoPrint server in safe "
"mode.</strong></p><p>This action may disrupt any ongoing print jobs "
"(depending on your printer's controller and general setup that might also"
" apply to prints run directly from your printer's internal storage)."
msgstr ""
"<strong>Você está prestes a reiniciar o servidor OctoPrint em modo de "
"segurança.</strong></p><p>Esta ação pode interromper qualquer trabalho de impressão em andamento (dependendo do controlador da sua impressora e da configuração geral, isso também pode se aplicar a impressões executadas diretamente do armazenamento interno da impressora)."

#: src/octoprint/static/js/app/dataupdater.js:104
